# Copy this file to `.env` and fill in a real API key generated from the
# WeatherAI developer dashboard: https://weather-ai.co/docs
#
# Format: wai_<key>
WEATHERAI_API_KEY=wai_your_api_key_here

# Base URL for the API under test. Override if testing against a staging
# environment.
WEATHERAI_BASE_URL=https://api.weather-ai.co
