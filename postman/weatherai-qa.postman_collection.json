    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "WX-070: X-RateLimit-* headers present and well-formed",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/v1/weather?lat=-1.2921&lon=36.8219&ai=false",
              "host": ["{{base_url}}"],
              "path": ["v1", "weather"],
              "query": [
                { "key": "lat", "value": "-1.2921" },
                { "key": "lon", "value": "36.8219" },
                { "key": "ai", "value": "false" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const limit = Number(pm.response.headers.get('X-RateLimit-Limit'));",
                  "const remaining = Number(pm.response.headers.get('X-RateLimit-Remaining'));",
                  "const reset = Number(pm.response.headers.get('X-RateLimit-Reset'));",
                  "pm.test('Rate limit headers are numeric and sane', () => {",
                  "  pm.expect(limit).to.be.a('number').and.not.NaN;",
                  "  pm.expect(remaining).to.be.a('number').and.not.NaN;",
                  "  pm.expect(reset).to.be.a('number').and.not.NaN;",
                  "  pm.expect(remaining).to.be.at.most(limit);",
                  "});"
                ]
              }
            }
          ]
        }
      ],
      "description": "NOTE: this folder intentionally does NOT include a request runner configured to fire hundreds of requests to trip the 429. The Free tier is capped at 1,000 requests/month total; deliberately exhausting it would block further exploratory testing on the assessment's only API key. See TEST_PLAN.md for the documented rationale and what a fuller rate-limit test would look like against a disposable/staging key."
    },
