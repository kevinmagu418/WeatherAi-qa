    {
      "name": "Consistency",
      "item": [
        {
          "name": "WX-060: repeat request #1 (run immediately followed by #2)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/v1/weather?lat=-1.2921&lon=36.8219&ai=false",
              "host": ["{{base_url}}"],
              "path": ["v1", "weather"],
              "query": [
                { "key": "lat", "value": "-1.2921" },
                { "key": "lon", "value": "36.8219" },
                { "key": "ai", "value": "false" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('wx060_first_forecast', JSON.stringify(pm.response.json().forecast.map(d => d.date)));"
                ]
              }
            }
          ]
        },
        {
          "name": "WX-060: repeat request #2 (compare to #1)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/v1/weather?lat=-1.2921&lon=36.8219&ai=false",
              "host": ["{{base_url}}"],
              "path": ["v1", "weather"],
              "query": [
                { "key": "lat", "value": "-1.2921" },
                { "key": "lon", "value": "36.8219" },
                { "key": "ai", "value": "false" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const firstDates = JSON.parse(pm.collectionVariables.get('wx060_first_forecast') || '[]');",
                  "const secondDates = pm.response.json().forecast.map(d => d.date);",
                  "pm.test('Forecast dates match previous request', () => {",
                  "  pm.expect(secondDates).to.eql(firstDates);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
