{
  "info": {
    "name": "WeatherAI QA Assessment",
    "description": "Exploratory / manual QA collection for the WeatherAI developer API (https://weather-ai.co/docs). Mirrors the automated Jest+Supertest suite in tests/ -- request names reference the matching test ID (e.g. WX-001) for traceability. Set the `api_key` collection variable (or an environment override) to a real key before running; never commit a real key into this file.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.weather-ai.co", "type": "string" },
    { "key": "api_key", "value": "wai_your_api_key_here", "type": "string" }
  ],
  "item": [
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "WX-001: valid lat/lon returns 200 with full schema",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/v1/weather?lat=-1.2921&lon=36.8219",
              "host": ["{{base_url}}"],
              "path": ["v1", "weather"],
              "query": [
                { "key": "lat", "value": "-1.2921" },
                { "key": "lon", "value": "36.8219" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "const body = pm.response.json();",
                  "pm.test('Has current block with expected types', () => {",
                  "  pm.expect(body.current).to.be.an('object');",
                  "  pm.expect(body.current.temperature).to.be.a('number');",
                  "  pm.expect(body.current.condition).to.be.a('string');",
                  "  pm.expect(body.current.humidity).to.be.a('number');",
                  "  pm.expect(body.current.windSpeed).to.be.a('number');",
                  "});",
                  "pm.test('Has non-empty forecast array with expected fields', () => {",
                  "  pm.expect(body.forecast).to.be.an('array').that.is.not.empty;",
                  "  body.forecast.forEach((day) => {",
                  "    pm.expect(day.date).to.be.a('string');",
                  "    pm.expect(day.maxTemp).to.be.a('number');",
                  "    pm.expect(day.minTemp).to.be.a('number');",
                  "    pm.expect(day.rainProbability).to.be.a('number');",
                  "  });",
                  "});",
                  "pm.test('AI summary present by default', () => pm.expect(body.summary).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "WX-002: ai=false omits summary (quota-saving path)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/v1/weather?lat=-1.2921&lon=36.8219&ai=false",
              "host": ["{{base_url}}"],
              "path": ["v1", "weather"],
              "query": [
                { "key": "lat", "value": "-1.2921" },
                { "key": "lon", "value": "36.8219" },
                { "key": "ai", "value": "false" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('summary field is absent when ai=false', () => pm.expect(body.summary).to.be.undefined);"
                ]
              }
            }
          ]
        },
        {
          "name": "WX-003: units=imperial returns plausible Fahrenheit range",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/v1/weather?lat=-1.2921&lon=36.8219&ai=false&units=imperial",
              "host": ["{{base_url}}"],
              "path": ["v1", "weather"],
              "query": [
                { "key": "lat", "value": "-1.2921" },
                { "key": "lon", "value": "36.8219" },
                { "key": "ai", "value": "false" },
                { "key": "units", "value": "imperial" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Temperature within plausible Fahrenheit range', () => {",
                  "  pm.expect(body.current.temperature).to.be.above(-100);",
                  "  pm.expect(body.current.temperature).to.be.below(150);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
